/**
 * Check if a user is logged in
 * @return bool
 */
function isLoggedIn() {
    return isset($_SESSION['user_id']) && !empty($_SESSION['user_id']);
}

/**
 * Check if logged-in user is admin
 * @return bool
 */
function isAdmin() {
    return isLoggedIn() && isset($_SESSION['user_role']) && $_SESSION['user_role'] == 'admin';
}

/**
 * Check if logged-in user is customer
 * @return bool
 */
function isCustomer() {
    return isLoggedIn() && isset($_SESSION['user_role']) && $_SESSION['user_role'] == 'customer';
}

/**
 * Check if logged-in user is business owner
 * @return bool
 */
function isBusinessOwner() {
    return isLoggedIn() && isset($_SESSION['user_role']) && $_SESSION['user_role'] == 'business_owner';
}

/**
 * Redirect to login page if not logged in
 */
function redirectIfNotLoggedIn() {
    if (!isLoggedIn()) {
        header('Location: ' . SITE_URL . '/login.html');
        exit();
    }
}

/**
 * Redirect to appropriate dashboard based on role
 */
function redirectToDashboard() {
    if (!isLoggedIn()) return;
    
    if (isAdmin()) {
        header('Location: ' . SITE_URL . '/admin/dashboard.php');
    } elseif (isBusinessOwner()) {
        header('Location: ' . SITE_URL . '/business/dashboard.php');
    } elseif (isCustomer()) {
        header('Location: ' . SITE_URL . '/customer/dashboard.php');
    } else {
        header('Location: ' . SITE_URL . '/home.html');
    }
    exit();
}

