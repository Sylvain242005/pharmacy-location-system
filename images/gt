/**
 * Get all facility types from database
 * @param mysqli $conn
 * @return array
 */
function getFacilityTypes($conn) {
    $result = $conn->query("SELECT DISTINCT facility_type FROM facilities ORDER BY facility_type");
    $types = [];
    if ($result) {
        while ($row = $result->fetch_assoc()) {
            $types[] = $row['facility_type'];
        }
    }
    // Default types if none exist
    if (empty($types)) {
        $types = ['pharmacy', 'hospital', 'clinic', 'other'];
    }
    return $types;
}

